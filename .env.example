# Environment Variables Template
# Copy this file to .env and fill in your actual API keys
# DO NOT commit .env files to version control

# ============================================
# VOCAREUM OPENAI API (Udacity Classroom)
# ============================================
# Get your Vocareum API key from the "Cloud Resources" tab in Udacity classroom
# Keys start with "voc-" prefix and must use Vocareum base URL
OPENAI_API_KEY="voc-your-vocareum-api-key-here"
OPENAI_API_BASE="https://openai.vocareum.com/v1"
UDACITY_OPENAI_API_KEY="voc-your-vocareum-api-key-here"

# ============================================
# STANDARD OPENAI API (Local Development)
# ============================================
# Uncomment and use these if you prefer your personal OpenAI key
# Get your key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY="sk-your-personal-openai-api-key"
# OPENAI_API_BASE="https://api.openai.com/v1"

# ============================================
# CHROMADB OPENAI EMBEDDINGS
# ============================================
# For ChromaDB vector database embeddings
# Can use the same key as OPENAI_API_KEY above
CHROMA_OPENAI_API_KEY="your-openai-api-key"

# ============================================
# TAVILY API (Web Search)
# ============================================
# Required for Module 06 (Web Search Agents) and Final Project
# Get your key from: https://tavily.com/
TAVILY_API_KEY="your-tavily-api-key"
